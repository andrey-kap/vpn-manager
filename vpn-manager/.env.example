# ==================== Environment Variables Example ====================
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ==================== Backend (Server) ====================

# JWT Secret для подписи токенов аутентификации
# Должен быть минимум 32 символа, содержать только alphanumeric, дефисы и подчеркивания
# Генерация: openssl rand -base64 32 | tr -d '/+=' | head -c 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# Путь к SQLite базе данных
# В Docker контейнере используйте /app/data/sqlite.db
DB_PATH=./data/sqlite.db

# Порт сервера
PORT=3000

# Путь к Docker сокету (для управления контейнерами StrongSwan)
# В Docker может потребоваться /var/run/docker.sock
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Уровень логирования: debug, info, warn, error
LOG_LEVEL=info

# Окружение: development, production, test
NODE_ENV=development

# ==================== Frontend (Web) ====================

# URL API бэкенда
# Для локальной разработки: http://localhost:3000
# Для продакшена: https://your-domain.com/api или http://api:3000 (внутри Docker network)
VITE_API_URL=http://localhost:3000

# Название приложения (опционально)
VITE_APP_NAME=VPN Manager

# Интервал обновления данных в мс (опционально, по умолчанию 30000)
VITE_REFRESH_INTERVAL=30000

# ==================== Production Notes ====================
# Для продакшена измените:
# 1. JWT_SECRET на случайную строку минимум 32 символа
# 2. VITE_API_URL на адрес вашего бэкенда (например, https://api.yourdomain.com)
# 3. NODE_ENV=production
# 4. При необходимости измените PORT и DOCKER_SOCKET_PATH
